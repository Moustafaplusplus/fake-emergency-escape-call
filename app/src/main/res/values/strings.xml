    <string name="about_title">About</string>
    <string name="about_disclaimer">This app schedules calls on your device only. It does not dial real numbers or contact emergency services.</string>
    <string name="about_ui_notice">Call screens look like a real phone for realism. This app is not your system Phone app or affiliated with your carrier.</string>
    <string name="about_version">Version %1$s (%2$d)</string>
    <string name="about_no_telephony">No cellular dialer, VoIP, or emergency routing is used.</string>
    <string name="about_voice_messages">You can type a message that is read aloud, or record a voice message that plays after you answer.</string>
    <string name="privacy_title">Privacy</string>
    <string name="privacy_body">Data stays on your device. No account or cloud sync.</string>
    <string name="privacy_local_only">Scheduled calls, text, voice recordings, templates, and settings are stored locally on your phone.</string>
    <string name="privacy_microphone">The microphone is used only when you choose voice recording. Recordings are not sent to our servers.</string>
    <string name="privacy_no_analytics">No analytics SDKs, crash reporters, or third-party tracking.</string>
