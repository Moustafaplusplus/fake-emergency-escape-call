    <string name="permissions_section_subtitle">Grant these for the best incoming-call experience. The app still works if you skip optional ones.</string>
    <string name="permission_notifications_title">Notifications</string>
    <string name="permission_notifications_desc">Required by Android for scheduled calls in the background. The full call screen opens automatically; no pop-up banner.</string>
    <string name="permission_exact_alarms_title">Exact alarms</string>
    <string name="permission_exact_alarms_desc">Keeps scheduled calls on time.</string>
    <string name="permission_full_screen_title">Full-screen incoming call</string>
    <string name="permission_full_screen_desc">Required on Android 14+ to show the call screen when the app is in the background.</string>
    <string name="permission_battery_title">Battery optimization</string>
    <string name="permission_battery_desc">Reduces delays from battery savers on some devices.</string>
